{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",

    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/*"]
    },


    "typeRoots": ["./node_modules/@types", "./src/types"]
  },

  "include": ["src/**/*", "*.ts"],
  "exclude": ["node_modules", "**/*.test.ts"]
}
